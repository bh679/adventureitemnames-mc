{
  "schemaVersion": 1,
  "id": "adventureitemnames",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "authors": ["${mod_authors}"],
  "contact": {
    "homepage": "https://github.com/bh679/adventureitemnames-mc",
    "sources": "https://github.com/bh679/adventureitemnames-mc",
    "issues": "https://github.com/bh679/adventureitemnames-mc/issues"
  },
  "license": "${mod_license}",
  "environment": "*",
  "entrypoints": {
    "main": ["games.brennan.adventureitemnames.fabric.AdventureItemNamesFabric"],
    "client": ["games.brennan.adventureitemnames.fabric.client.AdventureItemNamesFabricClient"],
    "modmenu": ["games.brennan.adventureitemnames.fabric.client.AdventureItemNamesModMenu"]
